---
layout: null
sitemap: false
---
{%- assign blog_docs = site.pages | where_exp: "p", "p.dir contains '/blogs/'" | where_exp: "p", "p.dir != '/blogs/'" | sort: "title" -%}
{%- assign sections = blog_docs | group_by: "blog_section" -%}
{
  "nodes": [
    {%- for blog in blog_docs -%}
    {%- assign section = blog.blog_section -%}
    {
      "id": {{ blog.url | jsonify }},
      "label": {{ blog.title | default: blog.name | jsonify }},
      "type": "blog",
      "section": {{ section | jsonify }},
      "url": {{ blog.url | relative_url | jsonify }}
    }{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
    {%- if blog_docs.size > 0 and sections.size > 0 -%},{%- endif -%}
    {%- for section in sections -%}
    {
      "id": {{ section.name | prepend: "section::" | jsonify }},
      "label": {{ section.name | jsonify }},
      "type": "section",
      "count": {{ section.items.size }}
    }{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ],
  "links": [
    {%- assign first = true -%}
    {%- for section in sections -%}
      {%- assign sectionid = section.name | prepend: "section::" -%}
      {%- for blog in section.items -%}
        {%- unless first -%},{%- endunless -%}
        { "source": {{ blog.url | jsonify }}, "target": {{ sectionid | jsonify }} }
        {%- assign first = false -%}
      {%- endfor -%}
    {%- endfor -%}
  ]
}
