---
layout: null
sitemap: false
---
{
  "nodes": [
    {%- for post in site.posts -%}
    {
      "id": {{ post.url | jsonify }},
      "label": {{ post.title | jsonify }},
      "type": "post",
      "date": {{ post.date | date: "%b %-d, %Y" | jsonify }},
      "url": {{ post.url | relative_url | jsonify }}
    }{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
    {%- if site.posts.size > 0 and site.tags.size > 0 -%},{%- endif -%}
    {%- for tag in site.tags -%}
    {
      "id": {{ tag[0] | prepend: "tag::" | jsonify }},
      "label": {{ tag[0] | jsonify }},
      "type": "tag",
      "count": {{ tag[1].size }}
    }{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ],
  "links": [
    {%- assign first = true -%}
    {%- for tag in site.tags -%}
      {%- assign tagid = tag[0] | prepend: "tag::" -%}
      {%- for post in tag[1] -%}
        {%- unless first -%},{%- endunless -%}
        { "source": {{ post.url | jsonify }}, "target": {{ tagid | jsonify }} }
        {%- assign first = false -%}
      {%- endfor -%}
    {%- endfor -%}
  ]
}
