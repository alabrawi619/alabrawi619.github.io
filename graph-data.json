---
layout: null
sitemap: false
---
{%- assign blog_docs = site.pages | where: "blog_document", true | sort: "title" -%}
{%- assign blog_tags = "" | split: "" -%}
{%- for blog in blog_docs -%}
  {%- if blog.tags -%}
    {%- assign blog_tags = blog_tags | concat: blog.tags -%}
  {%- endif -%}
{%- endfor -%}
{%- assign blog_tags = blog_tags | uniq | sort -%}
{
  "nodes": [
    {%- assign first = true -%}
    {%- for blog in blog_docs -%}
    {%- unless first -%},{%- endunless -%}
    {
      "id": {{ blog.url | jsonify }},
      "label": {{ blog.title | default: blog.name | jsonify }},
      "type": "blog",
      "section": {{ blog.blog_directory | jsonify }},
      "url": {{ blog.url | relative_url | jsonify }}
    }
    {%- assign first = false -%}
    {%- endfor -%}
    {%- for tag in blog_tags -%}
    {%- unless first -%},{%- endunless -%}
    {%- assign tag_count = 0 -%}
    {%- for blog in blog_docs -%}
      {%- if blog.tags contains tag -%}
        {%- assign tag_count = tag_count | plus: 1 -%}
      {%- endif -%}
    {%- endfor -%}
    {
      "id": {{ tag | prepend: "tag::" | jsonify }},
      "label": {{ tag | jsonify }},
      "type": "tag",
      "count": {{ tag_count }}
    }
    {%- assign first = false -%}
    {%- endfor -%}
  ],
  "links": [
    {%- assign first = true -%}
    {%- for blog in blog_docs -%}
      {%- for tag in blog.tags -%}
        {%- unless first -%},{%- endunless -%}
        { "source": {{ blog.url | jsonify }}, "target": {{ tag | prepend: "tag::" | jsonify }} }
        {%- assign first = false -%}
      {%- endfor -%}
    {%- endfor -%}
  ]
}
